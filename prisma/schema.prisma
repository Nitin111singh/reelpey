generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Platform {
  INSTAGRAM
  YOUTUBE
  TIKTOK
  TWITTER
  FACEBOOK
}

model User {
  id                     String               @id @default(uuid())
  username               String               @unique
  email                  String               @unique
  phoneNumber            String?
  password               String
  role                   Role                 @default(USER)
  isEmailVerified        Boolean              @default(false)
  emailVerificationToken String?
  resetPasswordToken     String?
  tokenExpiry            DateTime?
  resetPasswordTokenExpiry DateTime?
  totalViews             Int                  @default(0)
  moneyEarned            Float                @default(0)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  connectedAccounts      ConnectedAccount[]
  campaignSubmissions    CampaignSubmission[]

  @@index([email])
  @@index([username])
  @@map("users")
}

model ConnectedAccount {
  id                        String                    @id @default(uuid())
  userId                    String
  username                  String
  accountUrl                String
  verificationCode          String
  isVerified                Boolean                   @default(false)
  verifiedAt                DateTime?
  codeExpiresAt             DateTime
  manualVerificationStatus  VerificationRequestStatus @default(NONE)
  adminNotes                String?
  reviewedAt                DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, username])
  @@index([userId])
  @@index([verificationCode])
  @@index([manualVerificationStatus])
  @@map("connected_accounts")
}

/// Influencer marketing campaign created and managed by admins.
model Campaign {
  id                            String               @id @default(uuid())
  /// Storage keys (relative paths) for campaign images, e.g. "campaigns/abc123.webp".
  images                        String[]
  name                          String
  description                   String
  totalBudget                   Float
  /// Platforms this campaign is active on.
  supportedPlatforms            Platform[]
  /// Maximum number of submissions allowed per social-media account.
  maxSubmissionsPerAccount      Int
  /// Fee paid to each creator who participates.
  feePerCreator                 Float
  /// Maximum earning a creator can make per post.
  maxEarningPerPostPerCreator   Float
  status                        CampaignStatus       @default(ACTIVE)
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt
  submissions                   CampaignSubmission[]

  @@index([name])
  @@index([status])
  @@map("campaigns")
}

/// A video submission made by a user for a specific campaign.
model CampaignSubmission {
  id         String           @id @default(uuid())
  userId     String
  campaignId String
  videoLink  String
  status     SubmissionStatus @default(PENDING)
  views      Int              @default(0)
  earnings   Float            @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@map("campaign_submissions")
}

enum CampaignRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationRequestStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignStatus {
  ACTIVE
  COMPLETED
}

/// A campaign request submitted by a potential advertiser via the public form.
model CampaignRequest {
  id            String                @id @default(uuid())
  fullName      String
  email         String
  phoneNumber   String?
  title         String
  campaignGoals String
  status        CampaignRequestStatus @default(PENDING)
  adminNotes    String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([status])
  @@index([email])
  @@map("campaign_requests")
}
